# Sentinel Red-Teaming Toolkit — environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored; never commit actual tokens.

# API key for OpenAI-compatible endpoints (e.g. e-INFRA CZ, OpenAI, vLLM)
# Used by the openai-api adapter when no api_key is set in the manifest.
SENTINEL_API_KEY=your_api_token_here

# Fallback — also accepted by the openai-api adapter
# OPENAI_API_KEY=your_api_token_here
