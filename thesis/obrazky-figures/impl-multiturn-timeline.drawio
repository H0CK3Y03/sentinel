        <!-- Decision diamond after turn 2 -->
        <mxCell id="check" value="Loop&#10;exit?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
